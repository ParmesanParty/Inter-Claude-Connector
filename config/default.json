{
  "identity": "unnamed",
  "instance": null,
  "remotes": {},
  "server": {
    "port": 3179,
    "host": "0.0.0.0",
    "localToken": null,
    "peerTokens": {},
    "tls": {
      "enabled": false,
      "certPath": null,
      "keyPath": null,
      "caPath": null
    },
    "enrollPort": 4179,
    "corsOrigins": ["http://localhost:3180"]
  },
  "tls": {
    "ca": null
  },
  "transport": {
    "httpTimeout": 15000,
    "healthCheckInterval": 60000
  },
  "security": {
    "readfileEnabled": false,
    "execEnabled": false,
    "allowedPaths": ["~/code", "~/Code", "/tmp", "~/.icc"],
    "allowedCommands": ["ls", "cat", "head", "tail", "find", "grep", "git"],
    "allowedSubcommands": {
      "git": [
        "status", "log", "diff", "show", "branch", "tag",
        "shortlog", "blame", "reflog", "describe",
        "rev-parse", "ls-files", "ls-tree", "cat-file",
        "rev-list", "for-each-ref", "name-rev"
      ]
    },
    "maxExecTimeout": 30000
  },
  "claude": {
    "outputFormat": "json",
    "noSessionPersistence": true,
    "permissionMode": "default",
    "maxBudgetUsd": null,
    "systemPromptAppend": null
  }
}
